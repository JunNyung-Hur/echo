{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "echo",
  "version": "0.0.2",
  "identifier": "com.echo.app",
  "build": {
    "beforeDevCommand": "npm --prefix src-ui run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm --prefix src-ui run build",
    "frontendDist": "../src-ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "echo",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "publisher": "JunNyung-Hur",
    "copyright": "© 2026 JunNyung-Hur",
    "shortDescription": "Personal Second Brain",
    "longDescription": "echo — capture, transcribe, and refine your thoughts. A personal Second Brain that lives on your laptop."
  }
}
